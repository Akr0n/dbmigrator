<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DatabaseMigrator.Core.Models;assembly=DatabaseMigrator.Core"
        xmlns:converters="clr-namespace:DatabaseMigrator.Converters"
        x:Class="DatabaseMigrator.Views.MainWindow"
        Title="Database Migrator"
        Width="1400"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117"
        Icon="avares://DatabaseMigrator/Assets/logo.ico">

    <Window.Resources>
        <converters:LogLevelToForegroundConverter x:Key="LogLevelToForeground"/>
    </Window.Resources>

    <Window.Styles>
        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  DESIGN SYSTEM — GitHub-inspired dark palette           -->
        <!--  Page #0d1117 · Surface #161b22 · Border #30363d        -->
        <!--  Accent #58a6ff · Primary #1f6feb                       -->
        <!-- ═══════════════════════════════════════════════════════ -->

        <!-- Card: contenitore standard per ogni gruppo logico -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Typography -->
        <Style Selector="TextBlock.cardTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#58a6ff"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="TextBlock.fieldLabel">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8b949e"/>
        </Style>
        <Style Selector="TextBlock.body">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
        </Style>

        <!-- Inputs -->
        <Style Selector="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#0d1117"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#58a6ff"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#1f6feb"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#0d1117"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="RadioButton">
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Buttons -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1f6feb"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#388bfd"/>
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#1158c7"/>
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#1c2128"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#30363d"/>
        </Style>
        <Style Selector="Button.secondary:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <!-- TabControl / TabItem -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="#0d1117"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#c9d1d9"/>
        </Style>
        <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="#1c2128"/>
        </Style>
    </Window.Styles>

    <DockPanel Background="#0d1117">
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="#161b22" Foreground="#c9d1d9">
            <MenuItem Header="File">
                <MenuItem Header="Salva Configurazione..." x:Name="SaveConfigMenuItem"/>
                <MenuItem Header="Carica Configurazione..." x:Name="LoadConfigMenuItem"/>
                <Separator/>
                <MenuItem Header="Esci" x:Name="ExitMenuItem"/>
            </MenuItem>
            <MenuItem Header="Aiuto">
                <MenuItem Header="Informazioni" x:Name="AboutMenuItem"/>
            </MenuItem>
        </Menu>

        <Grid RowDefinitions="*,Auto" Background="#0d1117">
            <TabControl Grid.Row="0" x:Name="MainTabControl" Background="#0d1117" Foreground="#c9d1d9">

                <!-- Tab 1: Connections -->
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Connessioni Database"/>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" Margin="24" Background="#0d1117">
                            <!-- Source -->
                            <Border Grid.Row="0" Grid.Column="0" Classes="card" Margin="0,0,8,0">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="cardTitle" Text="Database Sorgente" Margin="0"/>
                                        <TextBlock x:Name="SourceStatusTextBlock" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Tipo Database"/>
                                        <ComboBox x:Name="SourceTypeCombo" SelectedIndex="0">
                                            <ComboBoxItem>SqlServer</ComboBoxItem>
                                            <ComboBoxItem>Oracle</ComboBoxItem>
                                            <ComboBoxItem>PostgreSQL</ComboBoxItem>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Server"/>
                                        <TextBox x:Name="SourceServerTextBox" Watermark="localhost"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Porta"/>
                                        <TextBox x:Name="SourcePortTextBox" Watermark="1433"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Database"/>
                                        <TextBox x:Name="SourceDatabaseTextBox" Watermark="database"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Username (opzionale)"/>
                                        <TextBox x:Name="SourceUsernameTextBox" Watermark="username"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Password (opzionale)"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0" x:Name="SourcePasswordTextBox" PasswordChar="•" Watermark="password"/>
                                            <Button Grid.Column="1" x:Name="SourcePasswordToggle"
                                                    Content="👁" Background="Transparent" Foreground="#8b949e"
                                                    Padding="10,0" FontSize="14" BorderThickness="0" Height="36"
                                                    Margin="4,0,0,0"
                                                    ToolTip.Tip="Mostra/nascondi password"/>
                                        </Grid>
                                    </StackPanel>
                                    <CheckBox x:Name="SourceTrustServerCertificateCheckBox" IsChecked="True">
                                        <TextBlock Text="Accetta certificato server (SSL) — consigliato per SQL Server in container" FontSize="11" TextWrapping="Wrap"/>
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <!-- Target -->
                            <Border Grid.Row="0" Grid.Column="1" Classes="card" Margin="8,0,0,0">
                                <StackPanel Spacing="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="cardTitle" Text="Database Target" Margin="0"/>
                                        <TextBlock x:Name="TargetStatusTextBlock" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Tipo Database"/>
                                        <ComboBox x:Name="TargetTypeCombo" SelectedIndex="2">
                                            <ComboBoxItem>SqlServer</ComboBoxItem>
                                            <ComboBoxItem>Oracle</ComboBoxItem>
                                            <ComboBoxItem>PostgreSQL</ComboBoxItem>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Server"/>
                                        <TextBox x:Name="TargetServerTextBox" Watermark="localhost"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Porta"/>
                                        <TextBox x:Name="TargetPortTextBox" Watermark="5432"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Database"/>
                                        <TextBox x:Name="TargetDatabaseTextBox" Watermark="database"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Username (opzionale)"/>
                                        <TextBox x:Name="TargetUsernameTextBox" Watermark="username"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="fieldLabel" Text="Password (opzionale)"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0" x:Name="TargetPasswordTextBox" PasswordChar="•" Watermark="password"/>
                                            <Button Grid.Column="1" x:Name="TargetPasswordToggle"
                                                    Content="👁" Background="Transparent" Foreground="#8b949e"
                                                    Padding="10,0" FontSize="14" BorderThickness="0" Height="36"
                                                    Margin="4,0,0,0"
                                                    ToolTip.Tip="Mostra/nascondi password"/>
                                        </Grid>
                                    </StackPanel>
                                    <CheckBox x:Name="TargetTrustServerCertificateCheckBox" IsChecked="True">
                                        <TextBlock Text="Accetta certificato server (SSL) — per SQL Server in container" FontSize="11" TextWrapping="Wrap"/>
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <!-- Connect Button -->
                            <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="ConnectButton"
                                    Classes="primary" Height="44" FontSize="13" Margin="0,16,0,0"
                                    Content="Connetti ai Database"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Tables -->
                <TabItem x:Name="TablesTab" IsEnabled="False">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="Selezione Tabelle"/>
                            <TextBlock x:Name="TablesSelectedBadge" FontSize="11" Foreground="#58a6ff" IsVisible="False" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,*" Margin="24" Background="#0d1117">
                        <!-- Search + actions Row -->
                        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Classes="card">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                <TextBox Grid.Column="0" x:Name="TableSearchTextBox" Watermark="Cerca tabelle per nome o schema..."/>
                                <Button Grid.Column="1" x:Name="ClearSearchButton" Classes="secondary" Content="×" Margin="8,0,0,0" Width="36" ToolTip.Tip="Cancella ricerca"/>
                                <Button Grid.Column="2" x:Name="SelectAllButton" Click="SelectAllButton_Click" Classes="primary" Content="Seleziona Tutto" Margin="8,0,0,0"/>
                                <Button Grid.Column="3" x:Name="DeselectAllButton" Click="DeselectAllButton_Click" Classes="secondary" Content="Deseleziona Tutto" Margin="8,0,0,0"/>
                                <Button Grid.Column="4" x:Name="RefreshSourceButton" Classes="secondary" Content="Aggiorna" Margin="8,0,0,0" ToolTip.Tip="Ricarica tabelle dal database sorgente"/>
                            </Grid>
                        </Border>

                        <!-- Sorgente: Tables List -->
                        <Border Grid.Row="1" Grid.Column="0" Classes="card" Margin="0,0,8,12">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Classes="cardTitle" x:Name="SourceTablesHeader" Text="Sorgente: seleziona tabelle"/>
                                <ListBox Grid.Row="1" x:Name="SourceTablesListBox" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" Foreground="#c9d1d9" CornerRadius="6">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:TableInfo}">
                                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="5,8">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Schema}" Foreground="#58a6ff" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="." Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding TableName}" Foreground="#c9d1d9" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding RowCount, StringFormat='({0} righe)'}" Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Target: Tables List (Display Only) -->
                        <Border Grid.Row="1" Grid.Column="1" Classes="card" Margin="8,0,0,12">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Classes="cardTitle" Text="Destinazione: schema da creare"/>
                                <ListBox Grid.Row="1" x:Name="TargetTablesListBox" Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" Foreground="#c9d1d9" CornerRadius="6">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:TableInfo}">
                                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="5,8">
                                                <TextBlock Text="{Binding Schema}" Foreground="#58a6ff" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="." Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding TableName}" Foreground="#3fb950" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding RowCount, StringFormat='({0} righe)'}" Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Statistics -->
                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Classes="card" Margin="0">
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock x:Name="SourceCountTextBlock" Classes="muted" Text="Tabelle sorgente: 0"/>
                                    <TextBlock x:Name="SelectedCountTextBlock" FontSize="12" FontWeight="SemiBold" Foreground="#58a6ff" Text="Tabelle selezionate: 0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock x:Name="TargetCountTextBlock" Classes="muted" Text="Tabelle destinazione: 0"/>
                                    <TextBlock x:Name="TotalRowsTextBlock" FontSize="12" FontWeight="SemiBold" Foreground="#3fb950" Text="Righe totali da migrare: 0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Tab 3: Migration -->
                <TabItem x:Name="MigrationTab" IsEnabled="False">
                    <TabItem.Header>
                        <TextBlock Text="Migrazione"/>
                    </TabItem.Header>
                    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="24" Background="#0d1117">
                        <!-- Migration Mode Selection -->
                        <Border Grid.Row="0" Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="cardTitle" Text="Modalità migrazione"/>
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <RadioButton x:Name="ModeSchemaAndData" GroupName="MigrationMode" IsChecked="True" Content="Schema + Dati"/>
                                    <RadioButton x:Name="ModeSchemaOnly" GroupName="MigrationMode" Content="Solo Schema"/>
                                    <RadioButton x:Name="ModeDataOnly" GroupName="MigrationMode" Content="Solo Dati"/>
                                </StackPanel>
                                <TextBlock x:Name="MigrationModeDescription" Classes="muted" TextWrapping="Wrap"
                                           Text="Crea le tabelle nel database di destinazione e copia tutti i dati. Se la tabella esiste già, verranno copiati solo i dati."/>
                            </StackPanel>
                        </Border>

                        <!-- Selected Tables Summary -->
                        <Border Grid.Row="1" Classes="card">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="cardTitle" Text="Tabelle da migrare"/>
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <TextBlock Text="{Binding SelectedTablesCount, StringFormat='Selezionate: {0}'}" Classes="body" FontWeight="SemiBold" Foreground="#58a6ff"/>
                                    <TextBlock Text="{Binding TotalRowsToMigrate, StringFormat='Righe totali: {0}'}" Classes="body" FontWeight="SemiBold" Foreground="#3fb950"/>
                                </StackPanel>
                                <ListBox Background="#0d1117" Foreground="#c9d1d9" MaxHeight="200" MinHeight="60" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6"
                                         ItemsSource="{Binding SelectedTablesForMigration}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:TableInfo}">
                                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="2,4">
                                                <TextBlock IsVisible="{Binding IsSelected}" Text="✓" Foreground="#3fb950" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Schema}" Foreground="#58a6ff" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Text="." Foreground="#8b949e" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding TableName}" FontSize="11" Foreground="#c9d1d9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding RowCount, StringFormat='({0} righe)'}" Foreground="#8b949e" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- Status -->
                        <Border Grid.Row="2" Classes="card">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Classes="cardTitle" Text="Stato"/>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="StatusTextBlock" Classes="body" TextWrapping="Wrap" MinHeight="100" Text="Pronto"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Progress bar -->
                        <Border Grid.Row="3" Classes="card">
                            <Grid>
                                <ProgressBar x:Name="ProgressBar" Value="0" Maximum="100" Height="24" Foreground="#3fb950" Background="#0d1117" CornerRadius="4"/>
                                <TextBlock x:Name="ProgressTextBlock" TextAlignment="Center" FontWeight="SemiBold" Foreground="White" FontSize="12" VerticalAlignment="Center" Text="0%"/>
                            </Grid>
                        </Border>

                        <Button x:Name="StartMigrationButton" Grid.Row="4" Classes="primary" Height="44" FontSize="13" Margin="0,4,0,0" IsEnabled="False"
                                Content="Avvia Migrazione"/>

                        <!-- Error box -->
                        <Border x:Name="ErrorBorder" Grid.Row="5" Background="#3a1015" CornerRadius="6" Padding="14" BorderBrush="#f85149" BorderThickness="1" Margin="0,12,0,0" IsVisible="False">
                            <TextBlock x:Name="ErrorTextBlock" Foreground="#ffa198" TextWrapping="Wrap" FontSize="11" Text=""/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Tab 4: Generazione Script -->
                <TabItem x:Name="ScriptTab" IsEnabled="False">
                    <TabItem.Header>
                        <TextBlock Text="Genera Script"/>
                    </TabItem.Header>
                    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="24" Background="#0d1117">

                        <!-- Options -->
                        <Border Grid.Row="0" Classes="card">
                            <StackPanel Spacing="14">
                                <TextBlock Classes="cardTitle" Text="Opzioni di esportazione"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Classes="fieldLabel" Text="Esporta per:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ScriptDialectCombo" SelectedIndex="0" Width="220">
                                        <ComboBoxItem>SQL Server</ComboBoxItem>
                                        <ComboBoxItem>PostgreSQL</ComboBoxItem>
                                        <ComboBoxItem>Oracle</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="24">
                                    <CheckBox x:Name="ScriptIncludeSchemaCheck" Content="Includi schema (DDL)" IsChecked="{Binding ScriptGeneration.IncludeSchema, Mode=TwoWay}"/>
                                    <CheckBox x:Name="ScriptIncludeDataCheck" Content="Includi dati (INSERT)" IsChecked="{Binding ScriptGeneration.IncludeData, Mode=TwoWay}"/>
                                    <CheckBox x:Name="ScriptIncludeDropCheck" Content="Aggiungi statement DROP" IsChecked="{Binding ScriptGeneration.IncludeDropStatements, Mode=TwoWay}"/>
                                </StackPanel>
                                <Button x:Name="ScriptLoadObjectsButton" Classes="secondary" HorizontalAlignment="Left"
                                        IsEnabled="{Binding !ScriptGeneration.IsBusy}" Content="Carica oggetti dalla sorgente"/>
                            </StackPanel>
                        </Border>

                        <!-- Search + filters -->
                        <Border Grid.Row="1" Classes="card">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                <TextBox Grid.Column="0" x:Name="ScriptSearchTextBox" Watermark="Cerca oggetti per nome o schema..."
                                         Text="{Binding ScriptGeneration.SearchFilter, Mode=TwoWay}"/>
                                <ComboBox Grid.Column="1" x:Name="ScriptTypeFilterCombo" SelectedIndex="0" Width="180" Margin="8,0,0,0">
                                    <ComboBoxItem>Tutti i tipi</ComboBoxItem>
                                    <ComboBoxItem>Tabelle</ComboBoxItem>
                                    <ComboBoxItem>Viste</ComboBoxItem>
                                    <ComboBoxItem>Stored Procedure</ComboBoxItem>
                                    <ComboBoxItem>Funzioni</ComboBoxItem>
                                    <ComboBoxItem>Trigger</ComboBoxItem>
                                    <ComboBoxItem>Sequenze</ComboBoxItem>
                                    <ComboBoxItem>Indici</ComboBoxItem>
                                </ComboBox>
                                <Button Grid.Column="2" x:Name="ScriptSelectAllButton" Classes="primary" Margin="8,0,0,0" Content="Seleziona tutto"/>
                                <Button Grid.Column="3" x:Name="ScriptDeselectAllButton" Classes="secondary" Margin="8,0,0,0" Content="Deseleziona tutto"/>
                            </Grid>
                        </Border>

                        <!-- Objects list -->
                        <Border Grid.Row="2" Classes="card">
                            <ListBox x:Name="ScriptObjectsListBox" ItemsSource="{Binding ScriptGeneration.Objects}"
                                     Background="#0d1117" BorderBrush="#30363d" BorderThickness="1" Foreground="#c9d1d9" CornerRadius="6">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DatabaseObject}">
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="5,6">
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                            <Border Background="#1f6feb" CornerRadius="3" Padding="6,2" VerticalAlignment="Center" MinWidth="110">
                                                <TextBlock Text="{Binding DisplayType}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="{Binding Schema}" Foreground="#58a6ff" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="." Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#c9d1d9" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding RowCount, StringFormat='({0} righe)'}" Foreground="#8b949e" FontSize="11"
                                                       VerticalAlignment="Center" IsVisible="{Binding ShowRowCount}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Counters + generate -->
                        <Border Grid.Row="3" Classes="card">
                            <Grid ColumnDefinitions="*,Auto" MinHeight="36">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock VerticalAlignment="Center" Classes="muted" FontWeight="SemiBold" Text="{Binding ScriptGeneration.TotalObjectsCount, StringFormat='Oggetti totali: {0}'}"/>
                                    <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="#58a6ff" Text="{Binding ScriptGeneration.SelectedCount, StringFormat='Selezionati: {0}'}"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="ScriptGenerateButton" Classes="primary" Height="36"
                                        IsEnabled="{Binding !ScriptGeneration.IsBusy}" Content="Genera Script su File..."/>
                            </Grid>
                        </Border>

                        <!-- Progress + status -->
                        <Border Grid.Row="4" Classes="card" Margin="0">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <ProgressBar x:Name="ScriptProgressBar" Value="{Binding ScriptGeneration.ProgressPercentage}" Maximum="100" Height="22" Foreground="#3fb950" Background="#0d1117" CornerRadius="4"/>
                                    <TextBlock TextAlignment="Center" FontWeight="SemiBold" Foreground="White" FontSize="11" VerticalAlignment="Center"
                                               Text="{Binding ScriptGeneration.ProgressPercentage, StringFormat='{}{0}%'}"/>
                                </Grid>
                                <TextBlock x:Name="ScriptStatusTextBlock" Classes="muted" TextWrapping="Wrap"
                                           Text="{Binding ScriptGeneration.StatusMessage}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Tab 5: Log -->
                <TabItem x:Name="LogTab">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="Log"/>
                            <Border x:Name="LogErrorBadge" Background="#da3633" CornerRadius="9" Padding="6,1" IsVisible="False">
                                <TextBlock x:Name="LogErrorBadgeText" Foreground="White" FontSize="10" FontWeight="SemiBold" Text="0"/>
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid RowDefinitions="Auto,*" Margin="24" Background="#0d1117">

                        <!-- Toolbar -->
                        <Border Grid.Row="0" Classes="card">
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="ClearLogButton" Classes="secondary"
                                            Content="Pulisci"
                                            ToolTip.Tip="Svuota il log in-app (il file su disco rimane invariato)"/>
                                    <Button x:Name="CopyLogButton" Classes="secondary"
                                            Content="Copia"
                                            ToolTip.Tip="Copia il log visibile negli appunti"/>
                                    <CheckBox x:Name="FilterErrorsCheckBox"
                                              Content="Solo Errori"
                                              VerticalContentAlignment="Center"
                                              Margin="8,0,0,0"
                                              ToolTip.Tip="Mostra solo le righe di errore"/>
                                    <Button x:Name="OpenLogFileButton" Classes="secondary"
                                            Content="Apri file log"
                                            ToolTip.Tip="Apre il file debug.log con l'applicazione predefinita"/>
                                </StackPanel>
                                <TextBlock x:Name="LogCountTextBlock"
                                           DockPanel.Dock="Right"
                                           Classes="muted"
                                           VerticalAlignment="Center" Margin="0,0,4,0"
                                           Text="0 voci"/>
                            </DockPanel>
                        </Border>

                        <!-- Log list -->
                        <Border Grid.Row="1" Classes="card" Margin="0" Padding="2">
                            <ListBox x:Name="LogListBox"
                                     Background="#0d1117"
                                     BorderThickness="0"
                                     CornerRadius="6"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:LogEntry}">
                                        <Grid ColumnDefinitions="85,52,*" Margin="6,2">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FormattedTime}"
                                                       Foreground="#6e7681"
                                                       FontFamily="Consolas,Courier New,Monospace"
                                                       FontSize="11"
                                                       VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding LevelTag}"
                                                       Foreground="{Binding Level, Converter={StaticResource LogLevelToForeground}}"
                                                       FontFamily="Consolas,Courier New,Monospace"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Top"
                                                       Margin="4,0"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Message}"
                                                       Foreground="{Binding Level, Converter={StaticResource LogLevelToForeground}}"
                                                       FontFamily="Consolas,Courier New,Monospace"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#1f6feb33"/>
                                    </Style>
                                </ListBox.Styles>
                            </ListBox>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Status Bar -->
            <Border Grid.Row="1" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="16,10">
                <DockPanel>
                    <TextBlock x:Name="StatusBarConnectionInfo"
                               DockPanel.Dock="Right" Foreground="#8b949e" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <TextBlock x:Name="StatusBarTextBlock" Foreground="#c9d1d9" FontSize="12" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
